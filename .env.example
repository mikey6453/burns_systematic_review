OPENAI_API_KEY=sk-...
KNOWLEDGE_BASE_PATH=./kb
QDRANT_PATH=./qdrant_data
COLLECTION_NAME=burns_papers
APPRAISALS_COLLECTION=burns_appraisals
EMBED_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini

# --- Appraisal / GRADE knobs ---
APPRAISE_RUNS=10              # independent grading runs per domain (spec default = 10)
APPRAISE_TEMPERATURE=0.5      # >0 needed for genuine inter-run variability
AGREEMENT_THRESHOLD=0.7       # judgments with <70% agreement get flagged for review
APPRAISE_K=6                  # chunks retrieved per domain (per-paper grading)
GRADE_K=12                    # chunks retrieved per GRADE domain (cross-corpus)
